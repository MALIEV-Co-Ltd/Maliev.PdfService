## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Status: Recommended
## Full list: https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you have tasks that create the project's static files in the wwwroot
#wwwroot/

# Visual Studio 2017 auto generated files
Generated\ Files/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent.log

# Build line numbers of unhandled exceptions (for use with Roslyn etc.)
*.StackTrace.txt

# JetBrains Rider intermediate and cache files
.idea/
*.sln.iml

# CodeRush personal settings extension
.cr/

# Python Tools for Visual Studio (PTVS)
__pycache__/
*.pyc

# Cake build
tools/
!tools/packages.config

# Tabs Studio settings
*.tabsstudio.settings

# Syncfusion WhiteList
Syncfusion.WhiteList.xml

# OpenCover settings
OpenCover/

# Kudu build output
artifacts/

# MyGet
web.config

# Roslyn
*.opened

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if using NuGet repositories to store project specific isolation modules
#!**/[Pp]ackages/

# Microsoft Azure Build Output
csx/
*.build.csdef

# Microsoft Azure Emulator
ecf/
rcf/

# Windows Azure Packaging Build Output
*.azurePubxml
*.azureServicePackages

# Others
sql/
*.Cache
ClientBin/
[Ss]tyle[Cc]op.[Cc]ache
~*
*~
*.log
*.swp
*.bak
*.cache
*.temp
[Tt]mp/
[Tt]emp/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Core
bin/
obj/
out/

# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# .env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

.claude/settings.local.json
.gemini/settings.local.json

# macOS files
.DS_Store

# Test Outputs
*test-output.txt
*_error.txt


# Test Outputs
*test-output.txt
*_error.txt


# Windows NUL device file (accidentally created by redirects)
NUL
